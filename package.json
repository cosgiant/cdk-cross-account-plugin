    "url": "https://github.com/Cumulus-Technology/cdk-cross-account-plugin"
  },
  "scripts": {
    "build": "tsc",
    "build-live": "tsc --watch",
    "lint": "eslint src tests",
    "test": "jest",
    "test:coverage": "jest --coverage",
