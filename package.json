    "@types/debug": "4.1.13",
    "@types/jest": "30.0.0",
    "@types/node": "^18.17.1",
    "eslint": "10.5.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "optionalDependencies": {
    "aws-cdk": "^2.95.1",
    "c9": "^3.1.3534"
  },
